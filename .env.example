# Alchemy API Key (https://dashboard.alchemy.com 에서 발급)
ALCHEMY_API_KEY=your_alchemy_api_key_here

# Ethereum Mainnet RPC URL (Alchemy API Key 포함)
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your_alchemy_api_key_here

# 체인 ID (Ethereum Mainnet = 1)
CHAIN_ID=1

# PostgreSQL 연결 문자열 (docker-compose 기본값)
DATABASE_URL=postgresql://postgres:password@localhost:5432/blockchain_indexer

# 서버 포트
PORT=3000
